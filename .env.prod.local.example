APP_ENV=prod
APP_DEBUG=0
APP_SECRET=change-this-secret
DEFAULT_URI=https://www.fceb.fr
# Exemple pour une base MySQL accessible directement sur le port 3306.
DATABASE_URL="mysql://fceb_user:change-this-password@127.0.0.1:3306/fceb_prod?serverVersion=8.0.32&charset=utf8mb4"
# Si la base est publiee sur un autre port local (par exemple 3307 via Docker), adaptez simplement l'hote, le port et les identifiants.
# DATABASE_URL="mysql://fceb:change-this-password@127.0.0.1:3307/fceb?serverVersion=8.0.32&charset=utf8mb4"
MAILER_DSN=null://null
