{% extends 'base.html.twig' %}

{% block title %}Mot de passe oublié | Cécifoot La Bassée{% endblock %}

{% block hero %}
    <section class="hero">
        <div class="hero-card">
            <div class="eyebrow">Compte</div>
            <h1>Réinitialiser mon mot de passe</h1>
            <p>Renseigne ton adresse e-mail pour recevoir un lien de réinitialisation.</p>
        </div>
    </section>
{% endblock %}

{% block body %}
    <article class="card wide" style="max-width: 560px; margin: 0 auto;">
        <div class="section-heading">
            <span class="eyebrow">Sécurité</span>
            <h2>Mot de passe oublié</h2>
        </div>
        {% if error %}
            <p class="muted"><strong>{{ error }}</strong></p>
        {% endif %}
        <form method="post">
            <label for="email"><strong>E-mail</strong></label>
            <input type="email" id="email" name="email" required style="width: 100%; padding: .9rem 1rem; border-radius: 14px; border: 1px solid var(--line); margin: .4rem 0 1rem;">
            <div class="meta-line">
                <button class="button primary" type="submit">Envoyer le lien</button>
                <a class="button secondary" href="{{ path('app_login') }}">Retour à la connexion</a>
            </div>
        </form>
    </article>
{% endblock %}
