{% extends 'base.html.twig' %}

{% block title %}Mot de passe oublié | Cécifoot La Bassée{% endblock %}

{% block hero %}
    <section class="hero">
        <div class="hero-card">
            <div class="eyebrow">Compte</div>
            <h1>Réinitialiser mon mot de passe</h1>
            <p>Renseigne ton adresse e-mail pour recevoir un lien de réinitialisation.</p>
        </div>
    </section>
{% endblock %}

{% block body %}
    <article class="card wide" style="max-width: 560px; margin: 0 auto;">
        <div class="section-heading">
            <span class="eyebrow">Sécurité</span>
            <h2>Mot de passe oublié</h2>
        </div>

        {{ form_start(forgotPasswordForm, {attr: {class: 'form-grid', style: 'margin-top: 1rem;'}}) }}
            <div class="form-errors">{{ form_errors(forgotPasswordForm) }}</div>

            <div class="field">
                {{ form_label(forgotPasswordForm.email) }}
                {{ form_widget(forgotPasswordForm.email) }}
                <div class="field-errors">{{ form_errors(forgotPasswordForm.email) }}</div>
            </div>

            <div class="form-actions">
                <button class="button primary" type="submit">Envoyer le lien</button>
                <a class="button secondary" href="{{ path('app_login') }}">Retour à la connexion</a>
            </div>
        {{ form_end(forgotPasswordForm) }}
    </article>
{% endblock %}
