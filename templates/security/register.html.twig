{% extends 'base.html.twig' %}

{% block title %}Inscription | Cécifoot La Bassée{% endblock %}

{% block hero %}
    <section class="hero">
        <div class="hero-card">
            <div class="eyebrow">Compte</div>
            <h1>Créer mon espace membre</h1>
            <p>Inscription simple pour accéder au menu compte et aux contenus membres.</p>
        </div>
    </section>
{% endblock %}

{% block body %}
    <article class="card wide" style="max-width: 560px; margin: 0 auto;">
        <div class="section-heading">
            <span class="eyebrow">Inscription</span>
            <h2>Créer un compte</h2>
        </div>
        {% if error %}
            <p class="muted"><strong>{{ error }}</strong></p>
        {% endif %}
        <form method="post">
            <label for="full_name"><strong>Nom complet</strong></label>
            <input type="text" id="full_name" name="full_name" required style="width: 100%; padding: .9rem 1rem; border-radius: 14px; border: 1px solid var(--line); margin: .4rem 0 1rem;">
            <label for="email"><strong>E-mail</strong></label>
            <input type="email" id="email" name="email" required style="width: 100%; padding: .9rem 1rem; border-radius: 14px; border: 1px solid var(--line); margin: .4rem 0 1rem;">
            <label for="password"><strong>Mot de passe</strong></label>
            <input type="password" id="password" name="password" required style="width: 100%; padding: .9rem 1rem; border-radius: 14px; border: 1px solid var(--line); margin: .4rem 0 1rem;">
            <div class="meta-line">
                <button class="button primary" type="submit">Créer mon compte</button>
                <a class="button secondary" href="{{ path('app_login') }}">J'ai déjà un compte</a>
            </div>
        </form>
    </article>
{% endblock %}
