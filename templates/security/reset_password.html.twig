{% extends 'base.html.twig' %}

{% block title %}Nouveau mot de passe | Cécifoot La Bassée{% endblock %}

{% block hero %}
    <section class="hero">
        <div class="hero-card">
            <h1>Choisir un nouveau mot de passe</h1>
            <p>Définis un nouveau mot de passe pour retrouver l’accès à ton compte.</p>
        </div>
    </section>
{% endblock %}

{% block body %}
    <article class="card wide" style="max-width: 560px; margin: 0 auto;">
        <div class="section-heading">
            <h2>Mettre à jour le mot de passe</h2>
        </div>

        {{ form_start(resetPasswordForm, {attr: {class: 'form-grid', style: 'margin-top: 1rem;'}}) }}
            <div class="form-errors">{{ form_errors(resetPasswordForm) }}</div>

            <div class="field">
                {{ form_label(resetPasswordForm.plainPassword.first) }}
                {{ form_widget(resetPasswordForm.plainPassword.first) }}
                <div class="field-errors">{{ form_errors(resetPasswordForm.plainPassword.first) }}</div>
            </div>

            <div class="field">
                {{ form_label(resetPasswordForm.plainPassword.second) }}
                {{ form_widget(resetPasswordForm.plainPassword.second) }}
                <div class="field-errors">
                    {{ form_errors(resetPasswordForm.plainPassword.second) }}
                    {{ form_errors(resetPasswordForm.plainPassword) }}
                </div>
            </div>

            <div class="form-actions">
                <button class="button primary" type="submit">Enregistrer</button>
                <a class="button secondary" href="{{ path('app_login') }}">Annuler</a>
            </div>
        {{ form_end(resetPasswordForm) }}
    </article>
{% endblock %}
