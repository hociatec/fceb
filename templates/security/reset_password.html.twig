{% extends 'base.html.twig' %}

{% block title %}Nouveau mot de passe | Cécifoot La Bassée{% endblock %}

{% block hero %}
    <section class="hero">
        <div class="hero-card">
            <div class="eyebrow">Compte</div>
            <h1>Choisir un nouveau mot de passe</h1>
            <p>Définis un nouveau mot de passe pour retrouver l’accès à ton compte.</p>
        </div>
    </section>
{% endblock %}

{% block body %}
    <article class="card wide" style="max-width: 560px; margin: 0 auto;">
        <div class="section-heading">
            <span class="eyebrow">Sécurité</span>
            <h2>Mettre à jour le mot de passe</h2>
        </div>
        {% if error %}
            <p class="muted"><strong>{{ error }}</strong></p>
        {% endif %}
        <form method="post">
            <label for="password"><strong>Nouveau mot de passe</strong></label>
            <input type="password" id="password" name="password" required style="width: 100%; padding: .9rem 1rem; border-radius: 14px; border: 1px solid var(--line); margin: .4rem 0 1rem;">
            <label for="confirm_password"><strong>Confirmer le mot de passe</strong></label>
            <input type="password" id="confirm_password" name="confirm_password" required style="width: 100%; padding: .9rem 1rem; border-radius: 14px; border: 1px solid var(--line); margin: .4rem 0 1rem;">
            <div class="meta-line">
                <button class="button primary" type="submit">Enregistrer</button>
                <a class="button secondary" href="{{ path('app_login') }}">Annuler</a>
            </div>
        </form>
    </article>
{% endblock %}
