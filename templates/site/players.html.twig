{% extends 'base.html.twig' %}

{% block title %}Effectif | Cécifoot La Bassée{% endblock %}

{% block hero %}
    <section class="hero">
        <div class="hero-card">
            <div class="page-hero">
                <div class="eyebrow"><span class="label-with-icon"><span class="icon-mark" aria-hidden="true"><svg viewBox="0 0 24 24" fill="none"><circle cx="12" cy="8" r="3.5" stroke="currentColor" stroke-width="2"/><path d="M5 20c1.5-3.5 4-5 7-5s5.5 1.5 7 5" stroke="currentColor" stroke-width="2" stroke-linecap="round"/></svg></span><span>Effectif</span></span></div>
                <h1>L'effectif de Cécifoot La Bassée</h1>
                <p class="page-lead">Découvre les joueurs qui portent le projet du club, leur profil, leur parcours et les repères essentiels pour mieux suivre l’équipe cette saison.</p>
                <div class="hero-stats">
                    <div class="hero-stat">
                        <strong>{{ players|length }}</strong>
                        <span>joueur{% if players|length > 1 %}s{% endif %} publié{% if players|length > 1 %}s{% endif %}</span>
                    </div>
                    <div class="hero-stat">
                        <strong>Collectif</strong>
                        <span>des profils à découvrir un par un</span>
                    </div>
                </div>
            </div>
        </div>
    </section>
{% endblock %}

{% block body %}
    <section class="stack">
        <article class="card wide">
            <div class="section-heading">
                <div>
                    <h2>Joueurs de l'effectif</h2>
                    <p class="muted">Une vue claire pour découvrir les profils publiés sur le site.</p>
                </div>
            </div>
            <div class="player-grid" style="margin-top: 1rem;">
                {% for player in players %}
                    {% set displayPhoto = player.displayPhoto %}
                    <article class="player-card">
                        <img class="player-photo" src="{{ displayPhoto ? asset('uploads/players/' ~ displayPhoto) : asset('assets/club-placeholder.svg') }}" alt="{{ player.name }}">
                        <div class="player-card-body">
                            <div class="player-card-meta">
                                <h3>{{ player.name }}</h3>
                                <div class="player-chip-row">
                                    {% if player.age %}
                                        <span class="tag">{{ player.age }} ans</span>
                                    {% endif %}
                                    {% if player.preferredPosition %}
                                        <span class="tag">{{ player.preferredPosition }}</span>
                                    {% endif %}
                                </div>
                            </div>
                            <div class="player-facts">
                                {% if player.nationality %}
                                    <span>Nationalité : {{ player.nationality }}</span>
                                {% endif %}
                                {% if player.preferredFoot %}
                                    <span>Pied : {{ player.preferredFoot }}</span>
                                {% endif %}
                            </div>
                            <p class="muted">
                                {% if player.description|length > 180 %}
                                    {{ player.description|slice(0, 180) ~ '...' }}
                                {% else %}
                                    {{ player.description }}
                                {% endif %}
                            </p>
                            <a class="button secondary" href="{{ path('site_player_show', {slug: player.slug}) }}">Découvrir {{ player.name }}</a>
                        </div>
                    </article>
                {% else %}
                    <p>Aucun joueur n'est encore publié dans l'effectif.</p>
                {% endfor %}
            </div>
        </article>
    </section>
{% endblock %}
