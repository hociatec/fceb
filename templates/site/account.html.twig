{% extends 'base.html.twig' %}

{% block title %}Mon compte | Cécifoot La Bassée{% endblock %}
{% block meta_description %}Consulte et mets à jour les informations de ton compte membre du Cécifoot La Bassée.{% endblock %}

{% block hero %}
    <section class="hero">
        <div class="hero-card">
            <h1>Mon compte</h1>
            <p>Consulte ton profil, mets à jour tes informations et gère la sécurité de ton compte.</p>
        </div>
    </section>
{% endblock %}

{% block body %}
    <section class="split">
        <article class="card tint">
            <span class="tag">Profil</span>
            <h2>{{ member.fullName }}</h2>
            <p class="muted">{{ member.email }}</p>
            <div class="list" style="margin-top: 1rem;">
                <div class="list-item">
                    <strong>Rôle{% if member.roles|length > 1 %}s{% endif %}</strong>
                    <div class="muted">{{ member.roles|join(', ') }}</div>
                </div>
                {% if is_granted('ROLE_EDITOR') %}
                    <div class="list-item">
                        <strong>Back-office</strong>
                        <div class="muted"><a href="{{ path('admin') }}">Ouvrir l’administration</a></div>
                    </div>
                {% endif %}
                <div class="list-item">
                    <strong>Sécurité</strong>
                    <div class="muted">
                        <form class="inline-form" method="post" action="{{ path('app_logout') }}">
                            <input type="hidden" name="_csrf_token" value="{{ csrf_token('logout') }}">
                            <button class="button secondary" type="submit">Se déconnecter</button>
                        </form>
                    </div>
                </div>
            </div>
        </article>

        <article class="card">
            <div class="section-heading">
                <div>
                    <h2>Gérer mon compte</h2>
                </div>
            </div>

            {{ form_start(accountForm, {attr: {class: 'form-grid', style: 'margin-top: 1rem;'}}) }}
                <div class="form-errors">{{ form_errors(accountForm) }}</div>

                <div class="field">
                    {{ form_label(accountForm.fullName) }}
                    {{ form_widget(accountForm.fullName) }}
                    <div class="field-errors">{{ form_errors(accountForm.fullName) }}</div>
                </div>

                <div class="field">
                    {{ form_label(accountForm.email) }}
                    {{ form_widget(accountForm.email) }}
                    <div class="field-errors">{{ form_errors(accountForm.email) }}</div>
                </div>

                <div class="field">
                    {{ form_label(accountForm.newPassword.first) }}
                    {{ form_widget(accountForm.newPassword.first) }}
                    <div class="field-errors">{{ form_errors(accountForm.newPassword.first) }}</div>
                </div>

                <div class="field">
                    {{ form_label(accountForm.newPassword.second) }}
                    {{ form_widget(accountForm.newPassword.second) }}
                    <div class="field-errors">
                        {{ form_errors(accountForm.newPassword.second) }}
                        {{ form_errors(accountForm.newPassword) }}
                    </div>
                </div>

                <div class="form-actions">
                    <button class="button primary" type="submit">Enregistrer les modifications</button>
                    <a class="button secondary" href="{{ path('app_forgot_password') }}">Mot de passe oublié</a>
                </div>
            {{ form_end(accountForm) }}
        </article>
    </section>
{% endblock %}
