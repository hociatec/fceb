{% extends 'base.html.twig' %}

{% block title %}Contact | Cécifoot La Bassée{% endblock %}

{% block hero %}
    <section class="hero">
        <div class="hero-card">
            <div class="page-hero">
                <div class="eyebrow"><span class="label-with-icon"><span class="icon-mark" aria-hidden="true"><svg viewBox="0 0 24 24" fill="none"><path d="M4 7.5 12 13l8-5.5" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/><rect x="3" y="5" width="18" height="14" rx="2.5" stroke="currentColor" stroke-width="2"/></svg></span><span>Contact</span></span></div>
                <h1>Écrire au club</h1>
                <p class="page-lead">Une demande, une prise de contact ou une question sur le cécifoot à La Bassée. Le formulaire centralise les messages et les informations utiles restent visibles au même endroit.</p>
            </div>
        </div>
    </section>
{% endblock %}

{% block body %}
    <section class="season-overview">
        <article class="card wide">
            <div class="section-heading">
                <div>
                    <h2><span class="label-with-icon"><span class="icon-mark" aria-hidden="true"><svg viewBox="0 0 24 24" fill="none"><path d="M4 7.5 12 13l8-5.5" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/><rect x="3" y="5" width="18" height="14" rx="2.5" stroke="currentColor" stroke-width="2"/></svg></span><span>Formulaire de contact</span></span></h2>
                    <p class="muted">Utilise ce formulaire pour une demande d'information, une prise de contact ou un message adressé au club.</p>
                </div>
            </div>
            <form method="post" class="form-grid" style="margin-top: 1rem;">
                <div>
                    <label for="name"><strong>Nom</strong></label>
                    <input id="name" name="name" type="text" value="{{ formData.name }}" required>
                </div>
                <div>
                    <label for="email"><strong>E-mail</strong></label>
                    <input id="email" name="email" type="email" value="{{ formData.email }}" required>
                </div>
                <div>
                    <label for="subject"><strong>Objet</strong></label>
                    <input id="subject" name="subject" type="text" value="{{ formData.subject }}">
                </div>
                <div>
                    <label for="message"><strong>Message</strong></label>
                    <textarea id="message" name="message" required>{{ formData.message }}</textarea>
                </div>
                <div>
                    <button class="button primary" type="submit">Envoyer le message</button>
                </div>
            </form>
        </article>

        <aside class="season-stats">
            <article class="season-stat">
                <strong>Club</strong>
                <span>Cécifoot La Bassée</span>
            </article>
            <article class="season-stat">
                <strong>E-mail</strong>
                <span>martine.cecifoot59@gmail.com</span>
            </article>
            <article class="season-stat">
                <strong>Téléphone</strong>
                <span>06 86 94 74 77</span>
            </article>
            <article class="season-stat">
                <strong>Adresse</strong>
                <span>Mairie de La Bassée, place du Général de Gaulle, 59480 La Bassée</span>
            </article>
        </aside>
    </section>
{% endblock %}
