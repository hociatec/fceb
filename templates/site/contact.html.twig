{% extends 'base.html.twig' %}

{% block title %}Contact | Cécifoot La Bassée{% endblock %}

{% block hero %}
    <section class="hero">
        <div class="hero-card">
            <div class="page-hero">
                <h1>Écrire au club</h1>
                <p class="page-lead">Une demande, une prise de contact ou une question sur le cécifoot à La Bassée. Le formulaire centralise les messages et les informations utiles restent visibles au même endroit.</p>
            </div>
        </div>
    </section>
{% endblock %}

{% block body %}
    <section class="season-overview">
        <article class="card wide">
            <div class="section-heading">
                <div>
                    <h2><span class="label-with-icon"><span class="icon-mark" aria-hidden="true"><svg viewBox="0 0 24 24" fill="none"><path d="M4 7.5 12 13l8-5.5" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/><rect x="3" y="5" width="18" height="14" rx="2.5" stroke="currentColor" stroke-width="2"/></svg></span><span>Formulaire de contact</span></span></h2>
                    <p class="muted">Utilise ce formulaire pour une demande d'information, une prise de contact ou un message adressé au club.</p>
                </div>
            </div>

            {{ form_start(contactForm, {attr: {class: 'form-grid', style: 'margin-top: 1rem;'}}) }}
                <div class="form-errors">{{ form_errors(contactForm) }}</div>

                <div class="field">
                    {{ form_label(contactForm.name) }}
                    {{ form_widget(contactForm.name) }}
                    <div class="field-errors">{{ form_errors(contactForm.name) }}</div>
                </div>

                <div class="field">
                    {{ form_label(contactForm.email) }}
                    {{ form_widget(contactForm.email) }}
                    <div class="field-errors">{{ form_errors(contactForm.email) }}</div>
                </div>

                <div class="field">
                    {{ form_label(contactForm.subject) }}
                    {{ form_widget(contactForm.subject) }}
                    <div class="field-errors">{{ form_errors(contactForm.subject) }}</div>
                </div>

                <div class="field">
                    {{ form_label(contactForm.message) }}
                    {{ form_widget(contactForm.message) }}
                    <div class="field-errors">{{ form_errors(contactForm.message) }}</div>
                </div>

                <div class="form-actions">
                    <button class="button primary" type="submit">Envoyer le message</button>
                </div>
            {{ form_end(contactForm) }}
        </article>

        <aside class="season-stats">
            <article class="season-stat">
                <strong>Club</strong>
                <span>{{ site.name }}</span>
            </article>
            <article class="season-stat">
                <strong>E-mail</strong>
                <span>{{ site.contact.email }}</span>
            </article>
            <article class="season-stat">
                <strong>Téléphone</strong>
                <span>{{ site.contact.phone }}</span>
            </article>
            <article class="season-stat">
                <strong>Adresse</strong>
                <span>{{ site.contact.address }}</span>
            </article>
        </aside>
    </section>
{% endblock %}
