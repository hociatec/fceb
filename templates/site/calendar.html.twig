{% extends 'base.html.twig' %}

{% block title %}Calendrier | Cécifoot La Bassée{% endblock %}

{% block hero %}
    <section class="hero">
        <div class="hero-card">
            <div class="page-hero">
                <h1>Calendrier de la saison</h1>
                {% if season %}
                    <p class="page-lead">{{ season.name }}. Le prochain rendez-vous ressort immédiatement, puis le reste du programme et les derniers résultats sont présentés plus clairement.</p>
                    <div class="hero-stats">
                        <div class="hero-stat">
                            <strong>{{ upcomingMatches|length }}</strong>
                            <span>match{% if upcomingMatches|length > 1 %}s{% endif %} à venir</span>
                        </div>
                        <div class="hero-stat">
                            <strong>{{ pastMatches|length }}</strong>
                            <span>match{% if pastMatches|length > 1 %}s{% endif %} déjà joué{% if pastMatches|length > 1 %}s{% endif %}</span>
                        </div>
                    </div>
                {% else %}
                    <p class="page-lead">Aucune saison n'est actuellement disponible.</p>
                {% endif %}
            </div>
        </div>
    </section>
{% endblock %}

{% block body %}
    {% set nextMatch = upcomingMatches|first %}
    {% set nextMatches = upcomingMatches|slice(1) %}

    <section class="stack">
        <section class="season-overview">
            <article class="card wide">
                <div class="section-heading">
                    <div>
                        <h2>Prochain rendez-vous</h2>
                        <p class="muted">Le prochain match mis en avant avec les informations pratiques.</p>
                    </div>
                </div>

                {% if nextMatch %}
                    <div class="story-inline" style="margin-top: 1rem;">
                        <div class="home-feature-article">
                            <span class="tag">À venir</span>
                            <div class="team-poster">
                                <div class="team-side">
                                    <img class="team-logo" src="{{ asset(team_logo(nextMatch.homeTeamName)) }}" alt="Logo de {{ nextMatch.homeTeamName }}">
                                    <strong>{{ nextMatch.homeTeamName }}</strong>
                                </div>
                                <span class="team-vs">vs</span>
                                <div class="team-side">
                                    <img class="team-logo" src="{{ asset(team_logo(nextMatch.awayTeamName)) }}" alt="Logo de {{ nextMatch.awayTeamName }}">
                                    <strong>{{ nextMatch.awayTeamName }}</strong>
                                </div>
                            </div>
                            <p><strong>{{ nextMatch.matchDate|date('d/m/Y H:i') }}</strong></p>
                            {% if nextMatch.location %}
                                <p>{{ nextMatch.location }}</p>
                            {% endif %}
                            {% if nextMatch.competition %}
                                <p class="muted">{{ nextMatch.competition }}</p>
                            {% endif %}
                            <div class="form-actions">
                                {% if nextMatch.location %}
                                    <a class="button secondary" href="https://www.google.com/maps/search/?api=1&query={{ nextMatch.location|url_encode }}" target="_blank" rel="noopener noreferrer">Voir l’accès</a>
                                {% endif %}
                                <a class="button secondary" href="{{ path('site_trial_request') }}">Venir découvrir le club</a>
                            </div>
                        </div>
                    </div>
                {% else %}
                    <p style="margin-top: 1rem;">Aucun match à venir n'est encore disponible.</p>
                {% endif %}
            </article>

            <aside class="season-stats">
                <article class="season-stat">
                    <strong>Saison</strong>
                    <span>{{ season ? season.name : 'Non renseignée' }}</span>
                </article>
                <article class="season-stat">
                    <strong>À venir</strong>
                    <span>{{ upcomingMatches|length }} match{% if upcomingMatches|length > 1 %}s{% endif %}</span>
                </article>
                <article class="season-stat">
                    <strong>Résultats enregistrés</strong>
                    <span>{{ pastMatches|length }} match{% if pastMatches|length > 1 %}s{% endif %}</span>
                </article>
            </aside>
        </section>

        <article class="card wide">
            <div class="section-heading">
                <div>
                    <h2>Suite du programme</h2>
                    <p class="muted">Les prochaines rencontres déjà planifiées après le prochain rendez-vous.</p>
                </div>
            </div>
            <div class="match-block">
                {% for match in nextMatches %}
                    <article class="match-card">
                        <div class="match-card-main">
                            <div class="team-poster">
                                <div class="team-side">
                                    <img class="team-logo" src="{{ asset(team_logo(match.homeTeamName)) }}" alt="Logo de {{ match.homeTeamName }}">
                                    <strong>{{ match.homeTeamName }}</strong>
                                </div>
                                <span class="team-vs">vs</span>
                                <div class="team-side">
                                    <img class="team-logo" src="{{ asset(team_logo(match.awayTeamName)) }}" alt="Logo de {{ match.awayTeamName }}">
                                    <strong>{{ match.awayTeamName }}</strong>
                                </div>
                            </div>
                            <div class="match-card-meta">
                                <span>{{ match.matchDate|date('d/m/Y H:i') }}</span>
                                {% if match.location %}<span>{{ match.location }}</span>{% endif %}
                                {% if match.competition %}<span>{{ match.competition }}</span>{% endif %}
                            </div>
                        </div>
                        <div class="match-card-side">
                            <span class="tag">À venir</span>
                        </div>
                    </article>
                {% else %}
                    <p>Aucun autre match à venir n'est encore disponible.</p>
                {% endfor %}
            </div>
        </article>

        <article class="card wide">
            <div class="section-heading">
                <div>
                    <h2>Derniers résultats</h2>
                    <p class="muted">Scores enregistrés et comptes-rendus publiés quand ils existent.</p>
                </div>
            </div>
            <div class="match-block">
                {% for match in pastMatches %}
                    {% set linkedArticle = matchArticles[match.id] ?? null %}
                    <article class="match-card">
                        <div class="match-card-main">
                            <div class="team-poster">
                                <div class="team-side">
                                    <img class="team-logo" src="{{ asset(team_logo(match.homeTeamName)) }}" alt="Logo de {{ match.homeTeamName }}">
                                    <strong>{{ match.homeTeamName }}</strong>
                                </div>
                                <span class="team-vs">vs</span>
                                <div class="team-side">
                                    <img class="team-logo" src="{{ asset(team_logo(match.awayTeamName)) }}" alt="Logo de {{ match.awayTeamName }}">
                                    <strong>{{ match.awayTeamName }}</strong>
                                </div>
                            </div>
                            <div class="match-card-meta">
                                <span>{{ match.matchDate|date('d/m/Y H:i') }}</span>
                                {% if match.location %}<span>{{ match.location }}</span>{% endif %}
                                {% if match.competition %}<span>{{ match.competition }}</span>{% endif %}
                            </div>
                            {% if linkedArticle %}
                                <p><a class="article-link" href="{{ path('site_article', {slug: linkedArticle.slug}) }}">{{ linkedArticle.excerpt ?: 'Lire le compte-rendu du match' }}</a></p>
                            {% endif %}
                        </div>
                        <div class="match-card-side">
                            {% if match.ourScore is not null %}
                                <span class="score">{{ match.ourScore }} - {{ match.opponentScore }}</span>
                            {% endif %}
                        </div>
                    </article>
                {% else %}
                    <p>Aucun match passé n'est encore disponible.</p>
                {% endfor %}
            </div>
        </article>
    </section>
{% endblock %}
