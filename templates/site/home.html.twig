{% extends 'base.html.twig' %}

{% block title %}Accueil | Cécifoot La Bassée{% endblock %}

{% block body %}
    <section class="home-stack">
        {% for section in homeSections %}
            {% set titleTag = section.titleTag|default('h2') %}
            {% set sectionClasses = [
                'card',
                section.layoutWidth|default('wide') == 'wide' ? 'wide',
                'home-section-card',
                'home-section-' ~ section.key,
                'home-section-align-' ~ (section.textAlignment|default('left')),
                'home-section-appearance-' ~ (section.appearance|default('default')),
                'home-section-tone-' ~ (section.accentTone|default('green'))
            ]|filter(v => v) %}
            {% set inlineClasses = [
                'story-inline',
                section.imagePosition|default('start') == 'end' ? 'story-inline-reverse'
            ]|filter(v => v) %}

            {% if section.key == 'intro' %}
                {% set introImage = section.image ? asset('uploads/home-sections/' ~ section.image) : (discoverPage and discoverPage.heroImage ? asset('uploads/pages/' ~ discoverPage.heroImage) : asset('assets/club-placeholder.svg')) %}
                <article class="{{ sectionClasses|join(' ') }}">
                    <div class="section-heading">
                        <div>
                            <{{ titleTag }}>{{ section.title }}</{{ titleTag }}>
                        </div>
                    </div>
                    <div class="{{ inlineClasses|join(' ') }}">
                        {% if section.showImage|default(true) %}
                            <img class="story-media tall" src="{{ introImage }}" alt="Visuel de présentation du club">
                        {% endif %}
                        <div class="home-feature-article">
                            {{ section.content|render_page_content }}
                        </div>
                    </div>
                </article>
            {% elseif section.key == 'featured_article' %}
                {% set featuredImage = section.image ? asset('uploads/home-sections/' ~ section.image) : (latestArticle and latestArticle.coverImage ? asset('uploads/articles/' ~ latestArticle.coverImage) : asset('assets/club-placeholder.svg')) %}
                <article class="{{ sectionClasses|join(' ') }}">
                    <div class="section-heading">
                        <div>
                            <{{ titleTag }}>{{ section.title }}</{{ titleTag }}>
                        </div>
                    </div>

                    {% if latestArticle %}
                        <div class="{{ inlineClasses|join(' ') }}">
                            {% if section.showImage|default(true) %}
                                <img class="story-media tall" src="{{ featuredImage }}" alt="{{ latestArticle.title }}">
                            {% endif %}
                            <div class="home-feature-article">
                                <h3><a class="article-link" href="{{ path('site_article', {slug: latestArticle.slug}) }}">{{ latestArticle.title }}</a></h3>
                                {% if section.showExcerpt|default(true) and latestArticle.excerpt %}
                                    <p>{{ latestArticle.excerpt }}</p>
                                {% endif %}
                                {% if section.showMeta|default(true) %}
                                    <div class="home-meta-row">
                                        <span>{{ latestArticle.publishedAt|date('d/m/Y H:i') }}</span>
                                        {% if latestArticle.season %}
                                            <span>{{ latestArticle.season.name }}</span>
                                        {% endif %}
                                    </div>
                                {% endif %}
                                {{ section.content|render_page_content }}
                            </div>
                        </div>
                    {% else %}
                        <p>Aucune actualité publiée.</p>
                    {% endif %}

                    {% if recentArticles is not empty %}
                        <div class="home-article-list">
                            {% for article in recentArticles %}
                                <article class="home-article-item">
                                    <div class="home-article-copy">
                                        <h3><a class="article-link" href="{{ path('site_article', {slug: article.slug}) }}">{{ article.title }}</a></h3>
                                        {% if section.showMeta|default(true) %}
                                            <p class="muted">{{ article.publishedAt|date('d/m/Y') }}{% if article.season %} · {{ article.season.name }}{% endif %}</p>
                                        {% endif %}
                                        {% if section.showExcerpt|default(true) and article.excerpt %}
                                            <p>{{ article.excerpt }}</p>
                                        {% endif %}
                                    </div>
                                </article>
                            {% endfor %}
                        </div>
                    {% endif %}
                </article>
            {% elseif section.key == 'next_match' %}
                {% set nextMatchImage = section.image ? asset('uploads/home-sections/' ~ section.image) : null %}
                <article class="{{ sectionClasses|join(' ') }}">
                    <div class="section-heading">
                        <div>
                            <{{ titleTag }}>{{ section.title }}</{{ titleTag }}>
                        </div>
                    </div>

                    {% if section.showImage|default(true) and nextMatchImage %}
                        <img class="story-media" src="{{ nextMatchImage }}" alt="Visuel du bloc {{ section.title }}">
                    {% endif %}

                    {% if nextMatch %}
                        <div class="home-feature-article">
                            <div class="team-poster">
                                <div class="team-side">
                                    <img class="team-logo" src="{{ asset(team_logo(nextMatch.homeTeamName)) }}" alt="Logo de {{ nextMatch.homeTeamName }}">
                                    <strong>{{ nextMatch.homeTeamName }}</strong>
                                </div>
                                <span class="team-vs">vs</span>
                                <div class="team-side">
                                    <img class="team-logo" src="{{ asset(team_logo(nextMatch.awayTeamName)) }}" alt="Logo de {{ nextMatch.awayTeamName }}">
                                    <strong>{{ nextMatch.awayTeamName }}</strong>
                                </div>
                            </div>
                            {% if section.showMeta|default(true) %}
                                <p class="muted">{{ nextMatch.matchDate|date('d/m/Y H:i') }}</p>
                                {% if nextMatch.location %}
                                    <p>{{ nextMatch.location }}</p>
                                {% endif %}
                                {% if nextMatch.competition %}
                                    <p class="muted">{{ nextMatch.competition }}</p>
                                {% endif %}
                            {% endif %}
                            {{ section.content|render_page_content }}
                        </div>

                        {% if otherUpcomingMatches is not empty and section.upcomingMatchesLimit|default(1) > 1 %}
                            <div class="home-match-grid">
                                {% for match in otherUpcomingMatches %}
                                    <article class="home-match-card">
                                        <div class="team-poster">
                                            <div class="team-side">
                                                <img class="team-logo small" src="{{ asset(team_logo(match.homeTeamName)) }}" alt="Logo de {{ match.homeTeamName }}">
                                                <strong>{{ match.homeTeamName }}</strong>
                                            </div>
                                            <span class="team-vs">vs</span>
                                            <div class="team-side">
                                                <img class="team-logo small" src="{{ asset(team_logo(match.awayTeamName)) }}" alt="Logo de {{ match.awayTeamName }}">
                                                <strong>{{ match.awayTeamName }}</strong>
                                            </div>
                                        </div>
                                        {% if section.showMeta|default(true) %}
                                            <p class="muted">{{ match.matchDate|date('d/m/Y H:i') }}{% if match.location %} · {{ match.location }}{% endif %}</p>
                                            {% if match.competition %}
                                                <p>{{ match.competition }}</p>
                                            {% endif %}
                                        {% endif %}
                                    </article>
                                {% endfor %}
                            </div>
                        {% endif %}
                    {% else %}
                        <p>Aucun match programmé.</p>
                    {% endif %}
                </article>

            {% elseif section.key == 'last_result' %}
                {% set lastResultImage = section.image ? asset('uploads/home-sections/' ~ section.image) : (lastMatchArticle and lastMatchArticle.coverImage ? asset('uploads/articles/' ~ lastMatchArticle.coverImage) : asset('assets/club-placeholder.svg')) %}
                <article class="{{ sectionClasses|join(' ') }}">
                    <div class="section-heading">
                        <div>
                            <{{ titleTag }}>{{ section.title }}</{{ titleTag }}>
                        </div>
                    </div>

                    {% if lastMatch %}
                        <div class="{{ inlineClasses|join(' ') }}">
                            {% if section.showImage|default(true) %}
                                <img class="story-media tall" src="{{ lastResultImage }}" alt="Illustration liée au dernier résultat du club">
                            {% endif %}
                            <div class="home-feature-article">
                                <div class="team-poster">
                                    <div class="team-side">
                                        <img class="team-logo" src="{{ asset(team_logo(lastMatch.homeTeamName)) }}" alt="Logo de {{ lastMatch.homeTeamName }}">
                                        <strong>{{ lastMatch.homeTeamName }}</strong>
                                    </div>
                                    <span class="team-vs">vs</span>
                                    <div class="team-side">
                                        <img class="team-logo" src="{{ asset(team_logo(lastMatch.awayTeamName)) }}" alt="Logo de {{ lastMatch.awayTeamName }}">
                                        <strong>{{ lastMatch.awayTeamName }}</strong>
                                    </div>
                                </div>
                                {% if lastMatchArticle and section.showExcerpt|default(true) %}
                                    <p>
                                        <a class="article-link" href="{{ path('site_article', {slug: lastMatchArticle.slug}) }}">
                                            {{ lastMatchArticle.excerpt ?: 'Voir le compte-rendu du match.' }}
                                        </a>
                                    </p>
                                {% endif %}
                                {% if section.showMeta|default(true) %}
                                    <p class="muted">{{ lastMatch.matchDate|date('d/m/Y H:i') }}{% if lastMatch.location %} · {{ lastMatch.location }}{% endif %}</p>
                                {% endif %}
                                {% if section.showScore|default(true) %}
                                    {% if lastMatch.ourScore is not null and lastMatch.opponentScore is not null %}
                                        <p><span class="score">{{ lastMatch.ourScore }} - {{ lastMatch.opponentScore }}</span></p>
                                    {% else %}
                                        <p class="muted">Score à renseigner.</p>
                                    {% endif %}
                                {% endif %}
                                {{ section.content|render_page_content }}
                            </div>
                        </div>
                    {% else %}
                        <p>Aucun résultat disponible.</p>
                    {% endif %}
                </article>
            {% endif %}
        {% endfor %}
    </section>
{% endblock %}

