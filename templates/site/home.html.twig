{% extends 'base.html.twig' %}

{% block title %}Accueil | Cécifoot La Bassée{% endblock %}

{% block body %}
    <section class="home-stack">
        {% if discoverPage %}
            <article class="card wide home-section-card">
                <div class="section-heading">
                    <div>
                        <h2>{{ site.homepage.intro_title }}</h2>
                        <p class="muted">{{ site.homepage.intro_subtitle }}</p>
                    </div>
                </div>
                <div class="story-inline">
                    <img class="story-media tall" src="{{ discoverPage.heroImage ? asset('uploads/pages/' ~ discoverPage.heroImage) : asset('assets/club-placeholder.svg') }}" alt="Visuel de présentation du club et de la pratique du cécifoot à La Bassée">
                    <div class="home-feature-article">
                        <span class="tag">Valeurs du club</span>
                        <p>{{ site.homepage.intro_lead }}</p>
                        <p class="muted">{{ site.homepage.intro_media_note }}</p>
                        <div class="value-grid">
                            <article class="value-card">
                                <strong>Engagement</strong>
                                <p>Chaque séance et chaque match reposent sur l’implication de tous.</p>
                            </article>
                            <article class="value-card">
                                <strong>Solidarité</strong>
                                <p>Le collectif prime, dans les repères du jeu comme dans la vie du groupe.</p>
                            </article>
                            <article class="value-card">
                                <strong>Progression</strong>
                                <p>Le club accompagne les joueurs avec exigence et envie de faire grandir chacun.</p>
                            </article>
                            <article class="value-card">
                                <strong>Ouverture</strong>
                                <p>Le cécifoot se découvre, se partage et se transmet sur le terrain comme en dehors.</p>
                            </article>
                        </div>
                        <div class="form-actions">
                            <a class="button secondary" href="{{ path('site_page', {slug: discoverPage.slug}) }}">{{ discoverPage.title }}</a>
                            <a class="button primary" href="{{ path('site_join') }}">Rejoindre le club</a>
                            <a class="button secondary" href="{{ path('site_trial_request') }}">Séance d’essai</a>
                        </div>
                    </div>
                </div>
            </article>
        {% endif %}

        <section class="home-stage">
            <article class="card home-stage-main">
                <div class="section-heading">
                    <div>
                        <h2>{{ site.homepage.featured_title }}</h2>
                        <p>{{ site.homepage.featured_subtitle }}</p>
                    </div>
                </div>

                {% if latestArticle %}
                    <div class="story-inline">
                        <img class="story-media tall" src="{{ latestArticle.coverImage ? asset('uploads/articles/' ~ latestArticle.coverImage) : asset('assets/club-placeholder.svg') }}" alt="Illustration de l’actualité {{ latestArticle.title }}">
                        <div class="home-feature-article">
                            <span class="tag">À la une</span>
                            <h3><a class="article-link" href="{{ path('site_article', {slug: latestArticle.slug}) }}">{{ latestArticle.title }}</a></h3>
                            {% if latestArticle.excerpt %}
                                <p>{{ latestArticle.excerpt }}</p>
                            {% endif %}
                            <div class="home-meta-row">
                                <span>{{ latestArticle.publishedAt|date('d/m/Y H:i') }}</span>
                                {% if latestArticle.season %}
                                    <span>{{ latestArticle.season.name }}</span>
                                {% endif %}
                            </div>
                            <p class="muted">Les actualités doivent montrer ce qui se passe réellement au club : matchs, événements, coulisses et vie associative.</p>
                        </div>
                    </div>
                {% else %}
                    <p>Aucune actualité publiée.</p>
                {% endif %}

                {% if recentArticles is not empty %}
                    <div class="home-subsection">
                        <div class="section-heading">
                            <div>
                                <h3>Autres actualités</h3>
                            </div>
                        </div>
                        <div class="home-article-list">
                            {% for article in recentArticles %}
                                <article class="home-article-item">
                                    <div class="home-article-copy">
                                        <strong><a class="article-link" href="{{ path('site_article', {slug: article.slug}) }}">{{ article.title }}</a></strong>
                                        <p class="muted">{{ article.publishedAt|date('d/m/Y') }}{% if article.season %} · {{ article.season.name }}{% endif %}</p>
                                        {% if article.excerpt %}
                                            <p>{{ article.excerpt }}</p>
                                        {% endif %}
                                    </div>
                                </article>
                            {% endfor %}
                        </div>
                    </div>
                {% endif %}
            </article>

            <aside class="home-stage-side">
                <article class="card">
                    <div class="section-heading">
                        <div>
                            <h2>{{ site.homepage.upcoming_title }}</h2>
                            <p>{{ site.homepage.upcoming_subtitle }}</p>
                        </div>
                    </div>

                    {% if nextMatch %}
                        <div class="home-feature-article">
                            <span class="tag">À venir</span>
                            <div class="team-poster">
                                <div class="team-side">
                                    <img class="team-logo" src="{{ asset(team_logo(nextMatch.homeTeamName)) }}" alt="Logo de {{ nextMatch.homeTeamName }}">
                                    <strong>{{ nextMatch.homeTeamName }}</strong>
                                </div>
                                <span class="team-vs">vs</span>
                                <div class="team-side">
                                    <img class="team-logo" src="{{ asset(team_logo(nextMatch.awayTeamName)) }}" alt="Logo de {{ nextMatch.awayTeamName }}">
                                    <strong>{{ nextMatch.awayTeamName }}</strong>
                                </div>
                            </div>
                            <p class="muted">{{ nextMatch.matchDate|date('d/m/Y H:i') }}</p>
                            {% if nextMatch.location %}
                                <p>{{ nextMatch.location }}</p>
                            {% endif %}
                            {% if nextMatch.competition %}
                                <p class="muted">{{ nextMatch.competition }}</p>
                            {% endif %}
                        </div>
                    {% else %}
                        <p>Aucun match programmé.</p>
                    {% endif %}
                </article>

                <article class="card">
                    <div class="section-heading">
                        <div>
                            <h2>Matchs à venir</h2>
                            <p>Les prochaines rencontres déjà programmées après le prochain rendez-vous.</p>
                        </div>
                    </div>

                    {% if otherUpcomingMatches is not empty %}
                        <div class="home-match-grid">
                            {% for match in otherUpcomingMatches %}
                                <article class="home-match-card">
                                    <div class="team-poster">
                                        <div class="team-side">
                                            <img class="team-logo small" src="{{ asset(team_logo(match.homeTeamName)) }}" alt="Logo de {{ match.homeTeamName }}">
                                            <strong>{{ match.homeTeamName }}</strong>
                                        </div>
                                        <span class="team-vs">vs</span>
                                        <div class="team-side">
                                            <img class="team-logo small" src="{{ asset(team_logo(match.awayTeamName)) }}" alt="Logo de {{ match.awayTeamName }}">
                                            <strong>{{ match.awayTeamName }}</strong>
                                        </div>
                                    </div>
                                    <p class="muted">{{ match.matchDate|date('d/m/Y H:i') }}{% if match.location %} · {{ match.location }}{% endif %}</p>
                                    {% if match.competition %}
                                        <p>{{ match.competition }}</p>
                                    {% endif %}
                                </article>
                            {% endfor %}
                        </div>
                    {% elseif nextMatch %}
                        <p class="muted">Aucun autre match n’est encore programmé après le prochain rendez-vous.</p>
                    {% else %}
                        <p>Aucun match à venir.</p>
                    {% endif %}
                </article>
            </aside>
        </section>

        <article class="card wide home-section-card">
            <div class="section-heading">
                <div>
                    <h2>{{ site.homepage.last_result_title }}</h2>
                    <p>{{ site.homepage.last_result_subtitle }}</p>
                </div>
            </div>

            {% if lastMatch %}
                <div class="story-inline">
                    {% if lastMatchArticle %}
                        <img class="story-media tall" src="{{ lastMatchArticle.coverImage ? asset('uploads/articles/' ~ lastMatchArticle.coverImage) : asset('assets/club-placeholder.svg') }}" alt="Illustration liée au dernier résultat du club">
                    {% endif %}
                    <div class="home-feature-article">
                        <span class="tag">Dernier résultat</span>
                        <div class="team-poster">
                            <div class="team-side">
                                <img class="team-logo" src="{{ asset(team_logo(lastMatch.homeTeamName)) }}" alt="Logo de {{ lastMatch.homeTeamName }}">
                                <strong>{{ lastMatch.homeTeamName }}</strong>
                            </div>
                            <span class="team-vs">vs</span>
                            <div class="team-side">
                                <img class="team-logo" src="{{ asset(team_logo(lastMatch.awayTeamName)) }}" alt="Logo de {{ lastMatch.awayTeamName }}">
                                <strong>{{ lastMatch.awayTeamName }}</strong>
                            </div>
                        </div>
                        {% if lastMatchArticle %}
                            <p>
                                <a class="article-link" href="{{ path('site_article', {slug: lastMatchArticle.slug}) }}">
                                    {{ lastMatchArticle.excerpt ?: 'Voir le compte-rendu du match.' }}
                                </a>
                            </p>
                        {% endif %}
                        <p class="muted">{{ lastMatch.matchDate|date('d/m/Y H:i') }}{% if lastMatch.location %} · {{ lastMatch.location }}{% endif %}</p>
                        <p><span class="score">{{ lastMatch.ourScore }} - {{ lastMatch.opponentScore }}</span></p>
                    </div>
                </div>
            {% else %}
                <p>Aucun résultat disponible.</p>
            {% endif %}
        </article>
    </section>
{% endblock %}
