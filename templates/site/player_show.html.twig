{% extends 'base.html.twig' %}

{% set displayPhoto = player.displayPhoto %}
{% set galleryPhotos = player.galleryPhotosForDisplay %}

{% block title %}{{ player.name }} | Effectif | Cécifoot La Bassée{% endblock %}
{% block meta_description %}{{ player.metaDescription ?: (player.description|trim|slice(0, 180) ~ (player.description|length > 180 ? '...' : '')) }}{% endblock %}
{% block og_title %}{{ player.metaTitle ?: player.name }} | Effectif | Cécifoot La Bassée{% endblock %}
{% block og_image %}{{ absolute_url(asset(displayPhoto ? 'uploads/players/' ~ displayPhoto : 'assets/club-placeholder.svg')) }}{% endblock %}

{% block hero %}
    <section class="hero">
        <div class="hero-card">
            <img class="hero-media" src="{{ displayPhoto ? asset('uploads/players/' ~ displayPhoto) : asset('assets/club-placeholder.svg') }}" alt="Portrait de {{ player.name }}">
            <div class="page-hero">
                <h1>{{ player.name }}</h1>
                <div class="hero-stats">
                    {% if player.age %}
                        <div class="hero-stat">
                            <strong>{{ player.age }} ans</strong>
                            <span>âge du joueur</span>
                        </div>
                    {% endif %}
                    {% if player.preferredPosition %}
                        <div class="hero-stat">
                            <strong>{{ player.preferredPosition }}</strong>
                            <span>poste préférentiel</span>
                        </div>
                    {% endif %}
                    {% if player.preferredFoot %}
                        <div class="hero-stat">
                            <strong>{{ player.preferredFoot }}</strong>
                            <span>pied préférentiel</span>
                        </div>
                    {% endif %}
                </div>
            </div>
        </div>
    </section>
{% endblock %}

{% block body %}
    <section class="stack">
        <article class="card wide player-profile">
            <div class="player-profile-media">
                <img class="player-photo large" src="{{ displayPhoto ? asset('uploads/players/' ~ displayPhoto) : asset('assets/club-placeholder.svg') }}" alt="{{ player.name }}">
            </div>
            <div class="player-profile-body">
                <div class="section-heading">
                    <div>
                        <h2>En savoir plus sur {{ player.name }}</h2>
                        <p class="muted">Présentation du joueur, de son rôle dans le collectif et de son parcours.</p>
                    </div>
                </div>
                <div class="player-facts player-facts-detailed">
                    {% if player.birthDate %}
                        <span>Date de naissance : {{ player.birthDate|date('d/m/Y') }}</span>
                    {% endif %}
                    {% if player.nationality %}
                        <span>Nationalité : {{ player.nationality }}</span>
                    {% endif %}
                    {% if player.preferredPosition %}
                        <span>Poste préférentiel : {{ player.preferredPosition }}</span>
                    {% endif %}
                    {% if player.preferredFoot %}
                        <span>Pied préférentiel : {{ player.preferredFoot }}</span>
                    {% endif %}
                </div>
                <div class="html-content">
                    {% for paragraph in player.description|split("\n") %}
                        {% if paragraph|trim is not empty %}
                            <p>{{ paragraph|trim }}</p>
                        {% endif %}
                    {% endfor %}
                </div>
                <div>
                    <a class="button secondary" href="{{ path('site_players') }}">Retour à l'effectif</a>
                </div>
            </div>
        </article>

        {% if galleryPhotos|length > 0 %}
            <article class="card wide">
                <div class="section-heading">
                    <div>
                        <h2>Photos de {{ player.name }}</h2>
                        <p class="muted">Des visuels complémentaires pour mieux présenter le joueur dans l'effectif.</p>
                    </div>
                </div>
                <div class="player-gallery-grid" style="margin-top: 1rem;">
                    {% for galleryPhoto in galleryPhotos %}
                        <figure class="player-gallery-item">
                            <img class="player-photo" src="{{ asset('uploads/players/' ~ galleryPhoto.photo) }}" alt="{{ galleryPhoto.caption ?: 'Photo de ' ~ player.name ~ ' ' ~ loop.index }}">
                            {% if galleryPhoto.caption %}
                                <figcaption class="player-gallery-caption">{{ galleryPhoto.caption }}</figcaption>
                            {% endif %}
                        </figure>
                    {% endfor %}
                </div>
            </article>
        {% endif %}
    </section>
{% endblock %}
