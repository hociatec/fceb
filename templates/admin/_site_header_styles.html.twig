<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Bitter:wght@500;600;700&family=Manrope:wght@400;500;600;700;800&display=swap" rel="stylesheet">
<style>
    html {
        --admin-panel-soft: rgba(255, 250, 243, 0.86);
        --admin-line: rgba(16, 32, 25, 0.12);
        --admin-gold-600: #b36f16;
        --admin-gold-500: #cf8a2e;
        --admin-green-950: #091a15;
        --admin-content-width: min(1240px, calc(100% - 2rem));
    }

    body {
        font-family: "Manrope", sans-serif;
    }

    .topbar {
        position: sticky;
        top: 0;
        z-index: 1000;
        backdrop-filter: blur(22px);
        background: linear-gradient(180deg, rgba(248, 242, 233, 0.92), rgba(244, 237, 227, 0.82));
        border-bottom: 1px solid rgba(16, 32, 25, 0.08);
        box-shadow: 0 12px 32px rgba(9, 26, 21, 0.07);
    }

    .topbar a {
        color: inherit;
        text-decoration: none;
    }

    .topbar .nav {
        width: var(--admin-content-width);
        margin: 0 auto;
        display: grid;
        gap: 1rem;
        padding: 1rem 0 1.05rem;
    }

    .topbar .nav-top,
    .topbar .nav-bottom {
        display: grid;
        align-items: center;
        gap: 1rem 1.4rem;
    }

    .topbar .nav-top {
        grid-template-columns: minmax(240px, 340px) minmax(0, 1fr);
    }

    .topbar .nav-bottom {
        grid-template-columns: 1fr;
        padding-top: .35rem;
    }

    .topbar .brand a {
        display: grid;
        gap: .5rem;
        padding: 1rem 1.1rem;
        border-radius: 26px;
        background:
            linear-gradient(180deg, rgba(255, 255, 255, 0.96), rgba(255, 249, 240, 0.8)),
            linear-gradient(135deg, rgba(207, 138, 46, 0.1), rgba(31, 95, 74, 0.12));
        border: 1px solid rgba(16, 32, 25, 0.08);
        box-shadow: 0 18px 36px rgba(9, 26, 21, 0.09);
    }

    .topbar .brand strong {
        font-family: "Bitter", serif;
        font-size: clamp(1.18rem, 1.45vw, 1.48rem);
        line-height: 1.1;
        letter-spacing: 0.025em;
        color: var(--admin-green-950);
    }

    .topbar .brand::after {
        content: "";
        display: block;
        width: 108px;
        height: 5px;
        margin-top: .2rem;
        border-radius: 999px;
        background: linear-gradient(90deg, var(--admin-accent), var(--admin-gold-500), #e4b15e);
    }

    .topbar .menu,
    .topbar .menu-right {
        display: flex;
        align-items: center;
        flex-wrap: wrap;
        gap: .7rem;
    }

    .topbar .menu {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(150px, 1fr));
        gap: .8rem;
        align-items: stretch;
        width: 100%;
        padding: 1rem;
        border-radius: 30px;
        background:
            linear-gradient(180deg, rgba(255, 255, 255, 0.9), rgba(249, 243, 233, 0.8)),
            var(--admin-panel-soft);
        border: 1px solid rgba(16, 32, 25, 0.08);
        box-shadow: 0 18px 38px rgba(9, 26, 21, 0.08);
    }

    .topbar .menu-right {
        justify-content: flex-end;
        gap: .65rem;
        padding: .42rem;
        border-radius: 999px;
        background: rgba(255, 255, 255, 0.62);
        border: 1px solid rgba(16, 32, 25, 0.08);
    }

    .topbar .utility-bar {
        display: flex;
        align-items: center;
        justify-content: flex-end;
        flex-wrap: wrap;
        gap: .7rem;
    }

    .topbar .icon-mark {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        width: 1.05rem;
        height: 1.05rem;
        flex: 0 0 auto;
        color: currentColor;
    }

    .topbar .icon-mark svg {
        width: 100%;
        height: 100%;
        display: block;
    }

    .topbar .label-with-icon {
        display: inline-flex;
        align-items: center;
        gap: .5rem;
    }

    .topbar .pill,
    .topbar .inline-form .pill {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        min-height: 44px;
        padding: .76rem 1.05rem;
        border-radius: 999px;
        border: 1px solid var(--admin-line);
        background: rgba(255, 255, 255, 0.84);
        color: var(--admin-ink);
        font-size: .92rem;
        font-weight: 700;
        letter-spacing: .01em;
        transition: transform .18s ease, border-color .18s ease, background-color .18s ease, color .18s ease, box-shadow .18s ease;
        box-shadow: 0 8px 18px rgba(9, 26, 21, 0.05);
    }

    .topbar .menu .pill {
        min-height: 78px;
        padding: 1rem 1.05rem;
        border-radius: 22px;
        justify-content: flex-start;
        text-align: left;
        align-items: flex-start;
        background: linear-gradient(180deg, rgba(255, 255, 255, 0.92), rgba(247, 242, 233, 0.82));
        box-shadow: inset 0 1px 0 rgba(255, 255, 255, 0.7);
    }

    .topbar .menu .pill .label-with-icon {
        width: 100%;
        align-items: flex-start;
        gap: .72rem;
    }

    .topbar .menu .pill .icon-mark {
        width: 1.15rem;
        height: 1.15rem;
        color: var(--admin-gold-600);
    }

    .topbar .pill:hover,
    .topbar .pill:focus-visible {
        transform: translateY(-2px);
        border-color: rgba(31, 95, 74, 0.28);
        background: linear-gradient(180deg, rgba(255, 255, 255, 0.98), rgba(237, 247, 241, 0.94));
        box-shadow: 0 14px 24px rgba(9, 26, 21, 0.08);
        outline: none;
    }

    .topbar .inline-form {
        display: inline-flex;
    }

    .main-header,
    .navbar-custom-menu {
        display: none;
    }

    .responsive-header {
        background: transparent;
        border-bottom: 0;
    }

    @media (max-width: 1120px) {
        .topbar .nav-top,
        .topbar .nav-bottom {
            grid-template-columns: 1fr;
            align-items: start;
        }

        .topbar .menu,
        .topbar .menu-right,
        .topbar .utility-bar {
            justify-content: flex-start;
        }

        .topbar .menu {
            grid-template-columns: repeat(3, minmax(0, 1fr));
        }
    }

    @media (max-width: 640px) {
        .topbar {
            position: static;
        }

        .topbar .nav {
            width: min(100%, calc(100% - 1rem));
            gap: .85rem;
            padding: .85rem 0 1rem;
        }

        .topbar .brand a {
            padding: .82rem .9rem;
        }

        .topbar .menu,
        .topbar .menu-right,
        .topbar .utility-bar {
            display: grid;
            gap: .7rem;
        }

        .topbar .menu,
        .topbar .menu-right {
            grid-template-columns: repeat(2, minmax(0, 1fr));
            width: 100%;
        }

        .topbar .menu {
            padding: .65rem;
            border-radius: 24px;
        }

        .topbar .pill {
            width: 100%;
            text-align: center;
            min-height: 46px;
        }
    }
</style>
